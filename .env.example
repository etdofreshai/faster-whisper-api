# Model: tiny, base, small, medium, large-v3, distil-large-v3, or any HF model id
WHISPER_MODEL=base

# Device: cpu or cuda
WHISPER_DEVICE=cpu

# Compute type: int8, int8_float16, float16, float32
WHISPER_COMPUTE_TYPE=int8

# Enable Silero VAD filter (true/false)
WHISPER_VAD=false

# Optional bearer token. If set, clients must send: Authorization: Bearer <key>
API_KEY=
